# Brook + VLC (temporary non-root UID override).
# HW accel plugins blacklisted — Brook has no GPU, so vaapi/vdpau produce
# opaque formats (VAOP/VDV0) that can't be converted to RV32 for wl_shm.
set wm
set vfb none
run --once /nix/bin/waylandd
run --uid 1000 /nix/profile/bin/vlc --no-plugins-cache --vout=wl_shm --aout=alsa --avcodec-hw=none --no-avcodec-dr --codec=avcodec,none --no-vaapi_filters --verbose=2 /boot/VIDEOS/sample-5s.mp4
