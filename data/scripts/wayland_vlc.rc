# Brook + VLC (temporary non-root UID override).
# HW accel disabled: LIBVA_DRIVERS_PATH/VDPAU_DRIVER in kernel envp +
# --avcodec-hw=none --no-avcodec-dr --codec=avcodec,none here.
set wm
set vfb none
run --once /nix/bin/waylandd
run --uid 1000 /nix/profile/bin/vlc --no-plugins-cache --vout=wl_shm --aout=alsa --avcodec-hw=none --no-avcodec-dr --codec=avcodec,none --verbose=2 /boot/VIDEOS/sample-5s.mp4
