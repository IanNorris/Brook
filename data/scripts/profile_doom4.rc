# Brook boot script: Profile 4x DOOM during rendering
# Usage: ./scripts/run-qemu.sh --script profile_doom4

set grid 2x2
set scale 2
set vfb 640x400

run doom -iwad /boot/DOOM1.WAD -frames 500
run doom -iwad /boot/DOOM1.WAD -frames 500
run doom -iwad /boot/DOOM1.WAD -frames 500
run doom -iwad /boot/DOOM1.WAD -frames 500

# Start profiler late — captures rendering phase (after WAD loading)
profile 8000
