# Brook + ffplay video playback via Wayland SHM.
# Uses software decode only (-hwaccel none) since Brook has no GPU.
# SDL3's Wayland backend provides the display surface.
set wm
set vfb none
run --once /nix/bin/waylandd
run --uid 1000 /nix/bin/ffplay -hwaccel none -autoexit -fs /boot/VIDEOS/sample-5s.mp4
