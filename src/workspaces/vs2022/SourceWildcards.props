<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<RootWildcard>../../**/</RootWildcard>
		
		<BuildSourceFiles>$(RootWildcard)*.cpp;$(RootWildcard)*.c;$(RootWildcard)*.h;$(RootWildcard)*.asm</BuildSourceFiles>
		<AuxFiles>$(RootWildcard)*.ld;$(RootWildcard)*.txt;$(RootWildcard)*.build</AuxFiles>
		<ScriptFiles>$(RootWildcard)*.py</ScriptFiles>
		
		<SourceWildcards>$(BuildSourceFiles);$(AuxFiles);$(ScriptFiles)</SourceWildcards>
	</PropertyGroup>
</Project>